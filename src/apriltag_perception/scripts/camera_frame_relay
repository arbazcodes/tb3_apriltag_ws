#!/usr/bin/env python3

"""
Gazebo camera publishes: frame_id = camera_rgb_frame which uses the robot/body frame convention:

x forward
y left
z up

But AprilTag pose estimation assumes the camera optical convention:

x right
y down
z forward

apriltag_ros interprets poses in the wrong coordinate system and the detected tag appears above the robot in RViz

This relay republishes Image and CameraInfo messages with: frame_id = camera_rgb_optical_frame

Only the frame label is changed so that apriltag_ros uses the correct camera coordinate convention


"""

import copy
import rclpy
from rclpy.node import Node
from sensor_msgs.msg import Image, CameraInfo


TARGET_FRAME = "camera_rgb_optical_frame"


class CameraFrameRelay(Node):
    def __init__(self):
        super().__init__("camera_frame_relay")

        self.create_subscription(Image, "/camera/image_raw", self.on_image, 10)
        self.create_subscription(CameraInfo, "/camera/camera_info", self.on_info, 10)

        self.image_pub = self.create_publisher(Image, "/camera/image_raw_optical", 10)
        self.info_pub = self.create_publisher(CameraInfo, "/camera/camera_info_optical", 10)

        self.get_logger().info("Relaying camera topics with frame_id=camera_rgb_optical_frame")

    def on_image(self, msg: Image):
        out = Image()
        out.header.stamp    = msg.header.stamp   # preserve original timestamp
        out.header.frame_id = TARGET_FRAME
        out.height          = msg.height
        out.width           = msg.width
        out.encoding        = msg.encoding
        out.is_bigendian    = msg.is_bigendian
        out.step            = msg.step
        out.data            = msg.data           # shared reference, not a copy
        self.image_pub.publish(out)

    def on_info(self, msg: CameraInfo):
        out = copy.copy(msg)
        out.header = copy.copy(msg.header)
        out.header.frame_id = TARGET_FRAME
        self.info_pub.publish(out)



def main(args=None):
    rclpy.init(args=args)
    node = CameraFrameRelay()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()